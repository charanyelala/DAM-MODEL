PORT=8080
DATA_DIR=./data/store
MANUAL_DATA_DIR=./data/manual

# ── ENTSO-E Transparency Platform ─────────────────────────────────────────────
# Register at https://transparency.entsoe.eu/ then email transparency@entsoe.eu
# requesting "Restful API access" — token arrives within 3 business days.
ENTSOE_TOKEN=
ENTSOE_DOMAIN=10YGR-HTSO-----Y

# Optional Groq explanation layer.
# Numeric forecasts still come from the market model; Groq only summarizes
# risks, data-quality blockers, and improvement actions from model output.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Scheduler ─────────────────────────────────────────────────────────────────
# UTC hours to auto-run the pipeline.
# 06:00 = morning refresh (weather + load updates)
# 13:00 = after Greek DAM closes (~12:30 local, 09:30 UTC) and ENTSO-E publishes D+1 prices
AUTO_RUN_ENABLED=true
AUTO_RUN_HOURS=6,13

# ── Weather nodes (name:lat:lon) ────────────────────────────────────────────
# Five nodes cover the main Greek grid regions + islands with high RES capacity
WEATHER_NODES=athens:37.9838:23.7275,thessaloniki:40.6401:22.9444,west_macedonia:40.3000:21.7900,peloponnese:37.5079:22.3735,central_greece:38.6044:22.7152

# ── Battery configuration ──────────────────────────────────────────────────
# Capacity and power limits — adjust to your asset spec sheet
BATTERY_CAPACITY_MWH=790
BATTERY_MAX_CHARGE_MW=330
BATTERY_MAX_DISCHARGE_MW=330
# One-way efficiencies: round-trip efficiency = charge × discharge = 0.95 × 0.95 ≈ 0.90
BATTERY_CHARGE_EFFICIENCY=0.95
BATTERY_DISCHARGE_EFFICIENCY=0.95
# SoC window: 10 %–95 % of capacity is a typical Li-NMC operating range
BATTERY_MIN_SOC_FRACTION=0.10
BATTERY_MAX_SOC_FRACTION=0.95
BATTERY_INITIAL_SOC_FRACTION=0.50
# Degradation cost in €/MWh of throughput (accounts for cycle aging)
BATTERY_DEGRADATION_EUR_PER_MWH=2.5
BATTERY_REPLACEMENT_EUR_PER_MWH=120000
BATTERY_CYCLE_LIFE_TO_80PCT=6000
BATTERY_CALENDAR_FADE_PCT_PER_YEAR=1.8
BATTERY_DEGRADATION_REFERENCE_TEMP_C=25
BATTERY_THERMAL_MANAGEMENT_DELTA_C=3
# Maximum equivalent full cycles per day (energy charged ≤ this × capacity)
# 1.5 cycles/day is conservative for a daily-arbitrage Li-ion asset
BATTERY_MAX_DAILY_CYCLES=1.5
# Synthetic digital twin baseline year from the 15-year LFP degradation table.
# Year 1 = 98% SOH / 300 EFC / 88.6% RTE. Use real BMS data when available.
BATTERY_TWIN_OPERATION_YEAR=1

# ── Data sources (all free, no key required unless noted) ───────────────────
# Open-Meteo:     https://open-meteo.com/           — free, no key
# Open-Meteo Ensemble: https://ensemble-api.open-meteo.com/ — free, no key
# PVGIS SARAH3:   https://re.jrc.ec.europa.eu/       — free, no key
# ADMIE/IPTO:     https://www.admie.gr/              — free, no key
# Commodity prices (Yahoo Finance): TTF=F, CO2.EUA=F — free, no key
